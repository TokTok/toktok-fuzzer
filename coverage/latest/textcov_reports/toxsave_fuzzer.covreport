  110|       |#endif
  111|       |
  112|       |    // Format message
  113|    573|    char msg[1024];
  114|    573|    va_list args;
  115|    573|    va_start(args, format);
  116|    573|    vsnprintf(msg, sizeof(msg), format, args);
