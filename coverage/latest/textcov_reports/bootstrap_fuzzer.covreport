  384|       |
  385|      5|    const uint8_t *packet_public_key = packet + 1 + CRYPTO_NONCE_SIZE;
  386|      5|    uint8_t shared_key[CRYPTO_SHARED_KEY_SIZE];
  387|      5|    get_shared_key(onion_a->mono_time, &onion_a->shared_keys_recv, shared_key, dht_get_self_secret_key(onion_a->dht),
  388|      5|                   packet_public_key);
  389|       |
  390|      5|    uint8_t plain[ONION_PING_ID_SIZE + CRYPTO_PUBLIC_KEY_SIZE + CRYPTO_PUBLIC_KEY_SIZE +
  391|      5|                                     ONION_ANNOUNCE_SENDBACK_DATA_LENGTH];
  392|      5|    int len = decrypt_data_symmetric(shared_key, packet + 1, packet + 1 + CRYPTO_NONCE_SIZE + CRYPTO_PUBLIC_KEY_SIZE,
  393|      5|                                     ONION_PING_ID_SIZE + CRYPTO_PUBLIC_KEY_SIZE + CRYPTO_PUBLIC_KEY_SIZE + ONION_ANNOUNCE_SENDBACK_DATA_LENGTH +
  394|      5|                                     CRYPTO_MAC_SIZE, plain);
  395|       |
  396|      5|    if ((uint32_t)len != sizeof(plain)) {
  397|      0|        return 1;
  398|      0|    }
  399|       |
  400|      5|    uint8_t ping_id1[ONION_PING_ID_SIZE];
  401|      5|    generate_ping_id(onion_a, mono_time_get(onion_a->mono_time), packet_public_key, source, ping_id1);
  402|       |
  403|      5|    uint8_t ping_id2[ONION_PING_ID_SIZE];
  404|      5|    generate_ping_id(onion_a, mono_time_get(onion_a->mono_time) + PING_ID_TIMEOUT, packet_public_key, source, ping_id2);
  405|       |
  406|      5|    int index;
  407|       |
  408|      5|    const uint8_t *data_public_key = plain + ONION_PING_ID_SIZE + CRYPTO_PUBLIC_KEY_SIZE;
  409|       |
  410|      5|    if (onion_ping_id_eq(ping_id1, plain)
  411|      5|            || onion_ping_id_eq(ping_id2, plain)) {
  412|      2|        index = add_to_entries(onion_a, source, packet_public_key, data_public_key,
  413|      2|                               packet + (ANNOUNCE_REQUEST_SIZE_RECV - ONION_RETURN_3));
  414|      3|    } else {
  415|      3|        index = in_entries(onion_a, plain + ONION_PING_ID_SIZE);
  416|      3|    }
  417|       |
  418|       |    /*Respond with a announce response packet*/
  419|      5|    Node_format nodes_list[MAX_SENT_NODES];
  420|      5|    unsigned int num_nodes =
  421|      5|        get_close_nodes(onion_a->dht, plain + ONION_PING_ID_SIZE, nodes_list, net_family_unspec, ip_is_lan(&source->ip));
  422|      5|    uint8_t nonce[CRYPTO_NONCE_SIZE];
  423|      5|    random_nonce(nonce);
  424|       |
  425|      5|    uint8_t pl[1 + ONION_PING_ID_SIZE + sizeof(nodes_list)];
  426|       |
  427|      5|    if (index == -1) {
  428|      2|        pl[0] = 0;
  429|      2|        memcpy(pl + 1, ping_id2, ONION_PING_ID_SIZE);
  430|      3|    } else {
  431|      3|        if (public_key_cmp(onion_a->entries[index].public_key, packet_public_key) == 0) {
  432|      2|            if (public_key_cmp(onion_a->entries[index].data_public_key, data_public_key) != 0) {
  433|      1|                pl[0] = 0;
  434|      1|                memcpy(pl + 1, ping_id2, ONION_PING_ID_SIZE);
  435|      1|            } else {
  436|      1|                pl[0] = 2;
  437|      1|                memcpy(pl + 1, ping_id2, ONION_PING_ID_SIZE);
  438|      1|            }
  439|      2|        } else {
  440|      1|            pl[0] = 1;
  441|      1|            memcpy(pl + 1, onion_a->entries[index].data_public_key, CRYPTO_PUBLIC_KEY_SIZE);
  442|      1|        }
  443|      3|    }
  444|       |
  445|      5|    int nodes_length = 0;
